# Copy this file to .env.
#
# Modes:
# - local-compose.yaml: local source build, direct host port mapping.
# - compose.yaml: template stack mode (Traefik + GHCR image).

# ------------------------------
# Deployment identity
# ------------------------------
# Compose project name prefix for container resources.
COMPOSE_PROJECT_NAME=tiktok-stream-relay

# Image repository and tag used by compose.yaml template stack mode.
GHCR_IMAGE=ghcr.io/ibbylabs/tiktok-stream-relay
IMAGE_TAG=latest

# ------------------------------
# Stack compose networking
# ------------------------------
# Shared docker network values (typically inherited from /opt/docker/.env).
DOCKER_DATA_DIR=./data
DOCKER_NETWORK=aio_default
DOCKER_NETWORK_EXTERNAL=false

# Required for compose.yaml stack mode.
# Example: relay.example.com
TIKTOK_STREAM_RELAY_HOSTNAME=

# ------------------------------
# Core runtime
# ------------------------------
PORT=3000
CACHE_ROOT=./cache

# Redis is optional for local use, required when PUBLIC_LAUNCH_MODE=true.
REDIS_URL=

# ------------------------------
# Debrid and source access
# ------------------------------
# Set false to run without Torbox.
DEBRID_ENABLED=true

# Required when DEBRID_ENABLED=true.
TORBOX_TOKEN=

# Optional TikTok auth cookie for improved fetch reliability.
TIKTOK_AUTH_COOKIE=

# ------------------------------
# Stream and cache limits
# ------------------------------
STREAM_TIMEOUT_MS=30000
STREAM_LOCAL_TTL_MS=172800000
STREAM_CACHE_MAX_BYTES=53687091200
SEARCH_MEMORY_TTL_MS=1800000
SEARCH_DISK_TTL_MS=86400000

# ------------------------------
# Search behavior
# ------------------------------
LIVE_SEARCH_MAX_RESULTS=36
SEARCH_MAX_LIMIT=60
SEARCH_RETRY_MAX_ATTEMPTS=2
SEARCH_RETRY_BASE_DELAY_MS=250

# ------------------------------
# Trending behavior
# ------------------------------
TRENDING_REFRESH_ON_STARTUP=false
TRENDING_REFRESH_INTERVAL_MS=21600000
TRENDING_SEED_QUERIES=sabrina carpenter,billie eilish,chappell roan,doechii,benson boone,lady gaga bruno mars
TRENDING_MAX_ITEMS=12

# ------------------------------
# Config portal and lifecycle controls
# ------------------------------
ADDON_CONFIG_ENABLED=true
ADDON_LIFECYCLE_ENABLED=true
ADDON_LINK_TTL_SECONDS=604800

# Required when PUBLIC_LAUNCH_MODE=true.
ADDON_LINK_SIGNING_KEYS=
ADDON_CRYPTO_SECRET=
ADMIN_TELEMETRY_TOKEN=

# Enables strict public hardening requirements.
PUBLIC_LAUNCH_MODE=false

# Optional comma-separated allowlist of client IPs for restricted surfaces.
PUBLIC_ALLOWLIST_IPS=
